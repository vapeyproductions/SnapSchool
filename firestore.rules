rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validRole(data) {
      return data.role == 'student' || data.role == 'administrator' || data.role == 'parent';
    }

    function validStudentMode(data) {
      return data.role != 'student'
        || data.studentMode in ['school', 'independent'];
    }

    match /users/{username} {
      // Signed-in users need to resolve one another by username when an
      // administrator creates an assignment.
      allow get: if signedIn();
      allow list: if false;

      // Anyone may choose either supported account type during registration,
      // but the new profile must belong to the authenticated Firebase user.
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username
        && validRole(request.resource.data)
        && validStudentMode(request.resource.data);

      // Account owners may edit their profile later, but cannot change the
      // identity, username, or role that authorization depends on.
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.username == resource.data.username
        && request.resource.data.role == resource.data.role
        && (
          request.resource.data.studentMode == resource.data.studentMode
          || (resource.data.role == 'student'
            && !('studentMode' in resource.data)
            && request.resource.data.studentMode == 'school')
        );

      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /profiles/{uid} {
      // UID-keyed profiles keep authorization and family connections stable
      // when an account owner changes their public username.
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && validRole(request.resource.data)
        && validStudentMode(request.resource.data);
      allow update: if signedIn()
        && uid == request.auth.uid
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && (
          request.resource.data.studentMode == resource.data.studentMode
          || (resource.data.role == 'student'
            && !('studentMode' in resource.data)
            && request.resource.data.studentMode == 'school')
        );
      allow delete: if false;
    }

    match /familyConnections/{connectionId} {
      allow get: if signedIn()
        && (resource.data.parentUid == request.auth.uid
          || resource.data.studentUid == request.auth.uid);
      allow list: if signedIn()
        && (resource.data.parentUid == request.auth.uid
          || resource.data.studentUid == request.auth.uid);

      // Parents initiate or re-send a request. Identity fields cannot be
      // changed after the connection record has been created.
      allow create: if signedIn()
        && request.resource.data.parentUid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if signedIn() && (
        (resource.data.parentUid == request.auth.uid
          && request.resource.data.parentUid == resource.data.parentUid
          && request.resource.data.studentUid == resource.data.studentUid
          && request.resource.data.status == 'pending')
        ||
        (resource.data.studentUid == request.auth.uid
          && request.resource.data.parentUid == resource.data.parentUid
          && request.resource.data.studentUid == resource.data.studentUid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt'])
          && request.resource.data.status in ['approved', 'rejected'])
      );
      allow delete: if signedIn()
        && (resource.data.parentUid == request.auth.uid
          || resource.data.studentUid == request.auth.uid);
    }

    match /channels/{channelId} {
      // These documents currently contain only streak counters. Stream holds
      // the assignment messages and membership data.
      allow read, create, update: if signedIn();
      allow delete: if false;
    }

    match /classes/{classId} {
      // Class rosters are private to their administrators. SchoolSnap's
      // authenticated server action performs the additional role check.
      allow get, list: if signedIn()
        && request.auth.uid in resource.data.administratorIds;

      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.administratorIds;

      allow update: if signedIn()
        && request.auth.uid in resource.data.administratorIds
        && request.auth.uid in request.resource.data.administratorIds;

      allow delete: if signedIn()
        && request.auth.uid in resource.data.administratorIds;
    }
  }
}
